  "typography": {
    "fontFamily": {
      "sans": "Inter, system-ui, -apple-system, sans-serif",
      "mono": "JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "fontSize": {
      "xs": "13px",
      "sm": "14px",
      "base": "15px",
      "lg": "17px",
      "xl": "19px",
      "2xl": "22px",
      "3xl": "26px",
      "4xl": "32px",
      "5xl": "38px"
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "snug": 1.375,
      "normal": 1.5,
      "relaxed": 1.625
    },
    "letterSpacing": {
      "tighter": "-0.02em",
      "tight": "-0.01em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.05em"
    }
  },

  "spacing": {
    "0": "0px",
    "0.5": "2px",
    "1": "4px",
    "1.5": "6px",
    "2": "8px",
    "2.5": "10px",
    "3": "12px",
    "3.5": "14px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "9": "36px",
    "10": "40px",
    "11": "44px",
    "12": "48px",
    "14": "56px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },

  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px",
    "2xl": "16px",
    "full": "9999px"
  },

  "shadow": {
    "xs": "0 1px 2px 0 rgba(0, 0, 0, 0.03)",
    "sm": "0 1px 3px 0 rgba(0, 0, 0, 0.04), 0 1px 2px -1px rgba(0, 0, 0, 0.03)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.03)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -4px rgba(0, 0, 0, 0.03)"
  },

  "layout": {
    "sidebarWidth": "240px",
    "sidebarCollapsed": "48px",
    "topbarHeight": "48px",
    "contentMaxWidth": "1280px",
    "pagePadding": "24px"
  },

  "transition": {
    "fast": "150ms ease",
    "default": "200ms ease",
    "slow": "300ms ease",
    "spring": "500ms cubic-bezier(0.34, 1.56, 0.64, 1)"
  },

  "zIndex": {
    "dropdown": 50,
    "sticky": 100,
    "overlay": 200,
    "modal": 300,
    "popover": 400,
    "toast": 500
  },

  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  }
}
